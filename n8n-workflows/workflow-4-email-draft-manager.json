      "main": [
        [{ "node": "Fetch Business Lead", "type": "main", "index": 0 }],
        [{ "node": "Fetch Job Lead", "type": "main", "index": 0 }]
      ]
    },
    "Fetch Business Lead": {
      "main": [[{ "node": "Merge Lead Data", "type": "main", "index": 0 }]]
    },
    "Fetch Job Lead": {
      "main": [[{ "node": "Merge Lead Data", "type": "main", "index": 1 }]]
    },
    "Merge Lead Data": {
      "main": [[{ "node": "Generate Email (Claude)", "type": "main", "index": 0 }]]
    },
    "Generate Email (Claude)": {
      "main": [[{ "node": "Parse Email Response", "type": "main", "index": 0 }]]
    },
    "Parse Email Response": {
      "main": [[{ "node": "Save Email Draft (Supabase)", "type": "main", "index": 0 }]]
    },
    "Save Email Draft (Supabase)": {
      "main": [[{ "node": "Respond to Webhook", "type": "main", "index": 0 }]]
    }
  },
  "settings": { "executionOrder": "v1" },
  "staticData": null,
  "tags": ["skill-hunter"],
  "meta": { "instanceId": "skill-hunter" }
}
